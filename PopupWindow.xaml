<Window x:Class="DevBar.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        SizeToContent="WidthAndHeight"
        MaxWidth="400"
        MaxHeight="600">
    <Border Background="#FF2D2D30" CornerRadius="8" Padding="8" BorderBrush="#FF3F3F46" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.4" ShadowDepth="2" />
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ItemsPanel" MinWidth="280" />
        </ScrollViewer>
    </Border>
</Window>
